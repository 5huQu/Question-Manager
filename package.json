{
  "name": "question-manager",
  "version": "0.1.1",
  "description": "Local-first desktop manager for slicing PDFs, OCR review, and math question collections.",
  "author": "Question Manager contributors",
  "private": false,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -n server,frontend -c blue,green \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "PORT=8797 tsx watch server/src/index.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts --host 127.0.0.1 --port 5174",
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc -p server/tsconfig.json",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "prepare:python-runtime": "node scripts/prepare-python-runtime.mjs",
    "verify:python-runtime": "node scripts/verify-python-runtime.mjs",
    "verify:packaged-python": "node scripts/verify-packaged-python.mjs",
    "test:updates": "node scripts/update-manifest.test.mjs",
    "desktop": "npm run build && npm run prepare:python-runtime && electron .",
    "pack:desktop": "npm run build && npm run prepare:python-runtime && electron-builder --dir && npm run verify:packaged-python",
    "pack:windows-installer": "npm run pack:desktop && electron-builder --win nsis --x64 --publish never",
    "test:math-render": "node server/scripts/validate_math_render.test.mjs",
    "test:routes": "npm run build:server && node server/scripts/route-contract.test.mjs",
    "test:smoke": "node server/scripts/smoke.test.mjs",
    "start": "PORT=8797 node server/dist/index.js"
  },
  "build": {
    "appId": "dev.question-manager.app",
    "productName": "Question Manager",
    "asar": false,
    "files": [
      "electron/**",
      "frontend/dist/**",
      "server/dist/**",
      "server/python/requirements.txt",
      "server/python/runtime-requirements.txt",
      "server/python/src/**",
      "server/python/scripts/**",
      "server/python/model_prompt_inventory_20260615.md",
      "server/python/ocr_prompt_settings.json",
      "server/tag_libraries/**",
      "templates/**",
      "LICENSE",
      "README.md",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "extraResources": [
      {
        "from": "runtime/python",
        "to": "python"
      }
    ],
    "mac": {
      "target": [
        "dir"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Question Manager",
      "uninstallDisplayName": "Question Manager",
      "deleteAppDataOnUninstall": false,
      "artifactName": "Question-Manager-Setup-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.577.0",
    "multer": "^2.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.21.0",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2"
  }
}
