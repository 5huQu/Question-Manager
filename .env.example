# Local OCR provider configuration.
# Copy this file to your app's local OCR settings screen or to a private env file.

OCR_API_BASE_URL=https://api.example.com/v1
OCR_API_KEY=
OCR_MODEL=

# Select `doc2x` for whole-PDF Doc2X v3 recognition, or `glm` for GLM-OCR.
OCR_PROVIDER=doc2x
DOC2X_API_BASE_URL=https://v2.doc2x.noedgeai.com
DOC2X_API_KEY=
DOC2X_MODEL=v3-2026

GLM_OCR_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4/layout_parsing
GLM_OCR_API_KEY=
GLM_OCR_MODEL=glm-ocr

# Optional AI assistant model for single-question cleanup and classification. Falls back to the OCR settings above when omitted.
OCR_CLEANUP_API_BASE_URL=
OCR_CLEANUP_API_KEY=
OCR_CLEANUP_MODEL=

# Optional local tool paths.
PYTHON_PATH=
XELATEX_PATH=
SOFFICE_PATH=

# PDF preview compilation. The SQLite-backed queue is shared by server
# processes that use the same QUESTION_DATA_DIR.
LAYOUT_PREVIEW_CONCURRENCY=1
LAYOUT_PREVIEW_POLL_MS=750
LAYOUT_PREVIEW_LEASE_MS=600000
LAYOUT_PREVIEW_CACHE_MAX_ENTRIES=50

# Optional data roots for source development.
QUESTION_DATA_DIR=
QUESTION_PYTHON_DATA_DIR=
