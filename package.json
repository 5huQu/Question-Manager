{
  "name": "question-manager",
  "version": "0.1.1",
  "description": "Local-first desktop manager for slicing PDFs, OCR review, and math question collections.",
  "author": "Question Manager contributors",
  "private": false,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -n server,frontend -c blue,green \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "node scripts/dev-server.mjs",
    "dev:frontend": "vite --config frontend/vite.config.ts --host 127.0.0.1 --port 5174",
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc -p server/tsconfig.json",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "typecheck:frontend": "tsc -p frontend/tsconfig.json --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:server && npm run typecheck:frontend",
    "prepare:python-runtime": "node scripts/prepare-python-runtime.mjs",
    "verify:python-runtime": "node scripts/verify-python-runtime.mjs",
    "verify:packaged-python": "node scripts/verify-packaged-python.mjs",
    "test:updates": "node scripts/update-manifest.test.mjs",
    "test:electron-security": "node scripts/electron-security.test.mjs",
    "test:frontend": "vitest run --config frontend/vitest.config.ts",
    "test:ocr-normalizer:built": "node server/scripts/ocr-document-normalizer.test.mjs",
    "test:ocr-normalizer": "npm run build:server && npm run test:ocr-normalizer:built",
    "test:question-parser:built": "node server/scripts/question-parser.test.mjs",
    "test:question-parser": "npm run build:server && npm run test:question-parser:built",
    "test:candidate-figure-move": "npm run build:server && node server/scripts/candidate-figure-move.test.mjs",
    "test:question-type": "npm run build:server && node server/scripts/question-type.test.mjs",
    "test:choice-layout": "npm run build:server && node server/scripts/choice-layout.test.mjs",
    "test:layout-drafts": "npm run build:server && node server/scripts/layout-drafts.service.test.mjs",
    "test:layout-pdf-e2e": "npm run build:server && node server/scripts/layout-pdf-e2e.test.mjs",
    "test:examzh-export": "npm run build:server && node server/scripts/examzh-export-setting.test.mjs",
    "desktop": "npm run build && npm run prepare:python-runtime && electron .",
    "pack:desktop": "npm run build && npm run prepare:python-runtime && electron-builder --dir && npm run verify:packaged-python",
    "pack:windows-installer": "npm run pack:desktop && electron-builder --win nsis --x64 --publish never",
    "test:math-render": "node server/scripts/validate_math_render.test.mjs",
    "test:routes:built": "node server/scripts/database-migrator.test.mjs && node server/scripts/v1-import-migration.test.mjs && node server/scripts/route-contract.test.mjs && node server/scripts/import-v2-runtime-schema.test.mjs && node server/scripts/import-job.service.test.mjs && node server/scripts/import-job-deletion.test.mjs && node server/scripts/import-job-list-performance.test.mjs && node server/scripts/upload-limits.test.mjs && node server/scripts/source-document-ocr-task.test.mjs && node server/scripts/quick-actions.test.mjs && node server/scripts/ai-cleaner.service.test.mjs && node server/scripts/candidate-manual-fix.test.mjs && node server/scripts/candidate-figure-move.test.mjs",
    "test:routes": "npm run build:server && npm run test:routes:built",
    "test:smoke": "node server/scripts/smoke.test.mjs",
    "test:unit": "npm run test:frontend && npm run test:math-render && npm run test:electron-security",
    "test:integration": "npm run build:server && npm run test:routes:built && npm run test:question-parser:built && npm run test:ocr-normalizer:built",
    "test:python": "PYTHONPATH=server/python python3 -m unittest discover -s server/python/tests -p 'test_*.py' -v",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:python",
    "check": "npm run typecheck && npm run test:all",
    "start": "node server/dist/index.js"
  },
  "build": {
    "appId": "dev.question-manager.app",
    "productName": "Question Manager",
    "asar": false,
    "files": [
      "electron/**",
      "frontend/dist/**",
      "server/dist/**",
      "server/python/requirements.txt",
      "server/python/runtime-requirements.txt",
      "server/python/src/ocr/__init__.py",
      "server/python/src/ocr/config.py",
      "server/python/scripts/classify_question_bank.py",
      "server/python/scripts/crop_manual_annotation.py",
      "server/python/scripts/render_pdf_page.py",
      "server/tag_libraries/**",
      "templates/**",
      "LICENSE",
      "README.md",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "extraResources": [
      {
        "from": "runtime/python",
        "to": "python"
      }
    ],
    "mac": {
      "target": [
        "dir"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "include": "installer/custom.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Question Manager",
      "uninstallDisplayName": "Question Manager",
      "deleteAppDataOnUninstall": false,
      "artifactName": "Question-Manager-Setup-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-table": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.577.0",
    "mathlive": "^0.110.0",
    "multer": "^2.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.6.0",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^6.0.4",
    "concurrently": "^9.2.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
