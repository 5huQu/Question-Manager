\RequirePackage{xcolor}
\RequirePackage{adjustbox}
\RequirePackage{fancyhdr}
\RequirePackage{lastpage}
\RequirePackage{needspace}
\RequirePackage{multicol}
\RequirePackage{etoolbox}
\RequirePackage{ifthen}
\RequirePackage[most]{tcolorbox}
\tcbuselibrary{skins,breakable}

%% ---- 字体 -------------------------------------------------------------
%% 中文：正文宋体，标题/标签/页眉用黑体风格；英文用 TeX Live 自带 Times-like 字体。
%% 数学字体保持 LaTeX 默认，避免 unicode-math 对既有公式与宏包产生额外兼容成本。
\setmainfont{texgyretermes-regular.otf}[
  BoldFont=texgyretermes-bold.otf,
  ItalicFont=texgyretermes-italic.otf,
  BoldItalicFont=texgyretermes-bolditalic.otf
]
\setsansfont{texgyreheros-regular.otf}[
  BoldFont=texgyreheros-bold.otf,
  ItalicFont=texgyreheros-italic.otf,
  BoldItalicFont=texgyreheros-bolditalic.otf
]
%% Apple 字体不随应用分发；优先使用本机字体，并回退到 Windows / TeX Live 字体。
\IfFontExistsTF{Songti SC}{
  \setCJKmainfont{Songti SC}[AutoFakeBold=2.5,AutoFakeSlant=.2]
}{
  \IfFontExistsTF{SimSun}{
    \setCJKmainfont{SimSun}[AutoFakeBold=2.5,AutoFakeSlant=.2]
  }{
    \setCJKmainfont{FandolSong-Regular.otf}[
      BoldFont=FandolSong-Bold.otf,
      AutoFakeSlant=.2
    ]
  }
}
\IfFontExistsTF{PingFang SC}{
  \setCJKsansfont{PingFang SC}[AutoFakeBold=2.5]
}{
  \IfFontExistsTF{SimHei}{
    \setCJKsansfont{SimHei}[AutoFakeBold=2.5]
  }{
    \setCJKsansfont{FandolHei-Regular.otf}[BoldFont=FandolHei-Bold.otf]
  }
}
\IfFontExistsTF{Kaiti SC}{
  \setCJKmonofont{Kaiti SC}
}{
  \IfFontExistsTF{KaiTi}{
    \setCJKmonofont{KaiTi}
  }{
    \setCJKmonofont{FandolKai-Regular.otf}
  }
}

\allowdisplaybreaks
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.42em}
\linespread{1.16}
\sloppy
% Avoid leaving a single first/last line of a question paragraph on another page.
\clubpenalty=10000
\widowpenalty=10000
\displaywidowpenalty=10000

%% ---- 配色（改这一段即可换主题）---------------------------------------
\definecolor{brandink}{HTML}{1B3A5B}   % 主色
\definecolor{brandtint}{HTML}{EEF3F8}  % 浅底
\definecolor{brandline}{HTML}{C9D3DC}  % 发丝线
\definecolor{brandwarm}{HTML}{A8762B}  % 暖点缀
\definecolor{brandalert}{HTML}{A23B2D} % 克制使用的强调

%% ---- 页面 -------------------------------------------------------------
\geometry{a4paper,top=20mm,bottom=20mm,left=20mm,right=20mm,headheight=26pt,headsep=10pt,footskip=22pt}

%% ---- 品牌配置宏（在 .tex 顶部改一处即可）-----------------------------
\newcommand*\qbank@brandname{教师姓名 · 工作室}
\newcommand*\qbank@brandmark{Q}
\newcommand*\qbank@tagline{\qbank@brandname}
\newcommand*\qbank@doctype{讲义}
\newcommand*\qbank@subject{}
\newcommand{\setbrandname}[1]{\renewcommand*\qbank@brandname{#1}}
\newcommand{\setbrandmark}[1]{\renewcommand*\qbank@brandmark{#1}}
\newcommand{\setbrandtagline}[1]{\renewcommand*\qbank@tagline{#1}}
\newcommand{\setdoctype}[1]{\renewcommand*\qbank@doctype{#1}}
\newcommand{\setsubject}[1]{\renewcommand*\qbank@subject{#1}}

%% ---- 文字字标 logo ----------------------------------------------------
%% 一个 brandink 圆角徽标（品牌首字/字形）+ 品牌名，纯 tcolorbox 实现，无需 tikz。
\newcommand{\qbankmark}{%
  \tcbox[on line,boxsep=0pt,left=3.4pt,right=3.4pt,top=1.6pt,bottom=1.6pt,%
    colback=brandink,coltext=white,colframe=brandink,arc=2.4pt,boxrule=0pt]%
    {\bfseries\sffamily\qbank@brandmark}%
  \hspace{0.45em}{\bfseries\sffamily\color{brandink}\qbank@brandname}%
}

%% ---- 页眉 / 页脚 ------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\qbankmark}
\fancyhead[R]{\small\sffamily\color{brandink}\qbank@doctype\ifx\qbank@subject\@empty\else\ \textcolor{brandline}{|}\ \qbank@subject\fi}
\fancyfoot[L]{\footnotesize\sffamily\color{brandink!75}\qbank@tagline}
\fancyfoot[R]{\footnotesize\sffamily\color{brandink!75}第 \thepage{} 页 \textcolor{brandline}{/} 共 \pageref{LastPage}{} 页}
\renewcommand{\headrule}{\vskip-2pt{\color{brandline}\hrule height 0.4pt}}
\renewcommand{\footrule}{{\color{brandline}\hrule height 0.4pt}\vskip2pt}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyhead[L]{\qbankmark}%
  \fancyhead[R]{\small\sffamily\color{brandink}\qbank@doctype\ifx\qbank@subject\@empty\else\ \textcolor{brandline}{|}\ \qbank@subject\fi}%
  \fancyfoot[L]{\footnotesize\sffamily\color{brandink!75}\qbank@tagline}%
  \fancyfoot[R]{\footnotesize\sffamily\color{brandink!75}第 \thepage{} 页 \textcolor{brandline}{/} 共 \pageref{LastPage}{} 页}%
}

%% ---- 标题块 -----------------------------------------------------------
\newcommand*\qbank@title{}
\newcommand*\qbank@subtitle{}
\newcommand*\qbank@meta{}
\newcommand{\doctitle}[1]{\renewcommand*\qbank@title{#1}}
\newcommand{\docsubtitle}[1]{\renewcommand*\qbank@subtitle{#1}}
\newcommand{\docmeta}[1]{\renewcommand*\qbank@meta{#1}}
\newcommand{\qbankmaketitle}{%
  \begin{center}
    {\color{brandline}\rule{\linewidth}{0.4pt}}\par\vspace{0.55em}
    {\sffamily\bfseries\LARGE\color{brandink}\qbank@title}\par
    \ifx\qbank@subtitle\@empty\else\vspace{0.35em}{\sffamily\large\color{brandink!80}\qbank@subtitle}\par\fi
    \ifx\qbank@meta\@empty\else\vspace{0.5em}{\small\color{brandink!70}\qbank@meta}\par\fi
    \vspace{0.55em}{\color{brandline}\rule{\linewidth}{0.4pt}}
  \end{center}
  \vspace{0.4em}
}

%% ---- 标题层级（用 ctex 的 \ctexset，避免与 titlesec 冲突）------------
\newcommand{\qbanksquare}{{\color{brandink}\rule[-0.08em]{0.5em}{0.92em}}\hspace{0.5em}}
\ctexset{%
  section/format = {\qbanksquare\sffamily\large\bfseries\color{brandink}},
  section/aftername = {\hspace{0.45em}},
  subsection/format = {\sffamily\normalsize\bfseries\color{brandink!85}},
  subsection/aftername = {\hspace{0.4em}},
}

%% ---- 知识点标签 / 难度标 ---------------------------------------------
\newcommand{\kptag}[1]{%
  \tcbox[on line,boxsep=0pt,left=4pt,right=4pt,top=1.2pt,bottom=1.2pt,%
    colback=brandtint,coltext=brandwarm,colframe=brandwarm!55,arc=3pt,boxrule=0.4pt]%
    {\scriptsize\sffamily #1}%
}
\newcommand{\difftag}[1]{%
  \ifthenelse{\equal{#1}{压轴}\OR\equal{#1}{较难}}%
    {{\scriptsize\sffamily\color{brandalert}\textbf{难度·#1}}}%
    {{\scriptsize\sffamily\color{brandink!75}难度·#1}}%
}
% \tagrow{难度}{标签1\kptag{...}...}：题目元信息行
\newcommand{\tagrow}[1]{%
  {\hspace{0.35em}\raggedright #1\par}%
  \vspace{0.18em}%
}

%% ---- 答案区（留白 + 发丝线 + 标签）-----------------------------------
\newdimen\qbank@answerheight
\newdimen\qbank@answerremain
\newdimen\qbank@answeroverhead
\newenvironment{answerarea}[1]{%
  % Finish the question text first so \pagetotal includes its final paragraph.
  % Measuring while still in horizontal mode can overestimate the available
  % height and move an otherwise empty answer area onto a new page.
  \par\nobreak
  \qbank@answerheight=#1\relax
  % Include paragraph/display glue and the label/rule, not only the blank area.
  % A conservative allowance is preferable to an answer area on its own page.
  \qbank@answeroverhead=5\baselineskip
  \ifdim\pagegoal<10000pt
    \qbank@answerremain=\pagegoal
    \advance\qbank@answerremain by -\pagetotal
    \advance\qbank@answerremain by -\qbank@answeroverhead
    \ifdim\qbank@answerheight>\qbank@answerremain
      \qbank@answerheight=\qbank@answerremain
    \fi
  \fi
  \ifdim\qbank@answerheight>0.8cm
    \addvspace{0.4em}%
    \noindent{\scriptsize\sffamily\color{brandink!55}作答区}\par\nobreak\vspace{0.15em}%
    \noindent{\color{brandline}\rule{\linewidth}{0.3pt}}\par\nobreak
    \vspace{\qbank@answerheight}%
  \fi
}{\par\addvspace{0.3em}}

%% ---- 解析区 -----------------------------------------------------------
\newtcolorbox{solutionbox}{%
  enhanced,breakable,colback=brandtint,colframe=brandink,
  boxrule=0pt,leftrule=2.2pt,arc=0.6mm,
  left=2.6mm,right=2.2mm,top=1.8mm,bottom=1.8mm,
  before skip=0.55em,after skip=0.55em,
  fontupper=\small\linespread{1.24}\selectfont}
\newcommand{\anslabel}{\textbf{\color{brandink}答案：}}
\newcommand{\sollabel}{\textbf{\color{brandwarm}解析：}}
\newcommand{\qbanklongmath}[1]{%
  \par\noindent
  \begin{adjustbox}{max width=\linewidth}
    $\displaystyle #1$
  \end{adjustbox}%
  \par
}
\newsavebox{\qbank@figbox}
\newcommand{\qbankfigure}[3]{%
  \par\addvspace{0.2em}\noindent
  % Keep diagrams visually comparable: wide figures retain their requested
  % width, while square/tall figures are capped at a common printed height.
  \sbox{\qbank@figbox}{\includegraphics[width=#2\linewidth,height=120pt,keepaspectratio]{#3}}%
  \typeout{QBANKFIG id=#1\space page=\thepage\space pagetotal=\the\pagetotal\space pagegoal=\the\pagegoal\space figheight=\the\ht\qbank@figbox\space figdepth=\the\dp\qbank@figbox\space width=#2}%
  \usebox{\qbank@figbox}%
  \par\addvspace{0.15em}%
}

%% ---- 题号 / 题目环境（试卷、练习单共用）-----------------------------
\newcolumntype{Y}{>{\raggedright\arraybackslash}X}
\newcommand{\qbankchoicecell}[2]{\textbf{#1.}\hspace{0.35em}#2}
\newcommand{\qbankchoicesfour}[4]{%
  \par\addvspace{0.25em}\noindent
  \begin{tabularx}{\linewidth}{@{}YYYY@{}}
    \qbankchoicecell{A}{#1} & \qbankchoicecell{B}{#2} & \qbankchoicecell{C}{#3} & \qbankchoicecell{D}{#4}
  \end{tabularx}%
  \par\addvspace{0.1em}%
}
\newcommand{\qbankchoicestwo}[4]{%
  \par\addvspace{0.25em}\noindent
  \begin{tabularx}{\linewidth}{@{}YY@{}}
    \qbankchoicecell{A}{#1} & \qbankchoicecell{B}{#2}\\[0.18em]
    \qbankchoicecell{C}{#3} & \qbankchoicecell{D}{#4}
  \end{tabularx}%
  \par\addvspace{0.1em}%
}
\newenvironment{qbankchoicesone}{%
  \begin{enumerate}[label=\textbf{\Alph*.},leftmargin=2.2em,itemsep=0.15em,topsep=0.25em]
}{\end{enumerate}}

% Stable, non-floating figure/choice composition. Both minipages remain in one
% vertical block, so a figure can never land between individual choices.
\newcommand{\qbankchoiceswithfigure}[3]{%
  \par\addvspace{0.25em}\noindent
  \ifstrequal{#1}{left}{%
    \begin{minipage}[t]{0.40\linewidth}\centering #2\end{minipage}\hfill
    \begin{minipage}[t]{0.56\linewidth}#3\end{minipage}%
  }{%
    \begin{minipage}[t]{0.56\linewidth}#3\end{minipage}\hfill
    \begin{minipage}[t]{0.40\linewidth}\centering #2\end{minipage}%
  }%
  \par\addvspace{0.1em}%
}

\newcommand*\qbank@currentquestion{}
\newenvironment{examquestion}[2]{%
  % Reserve only a question start. A fixed full-question reservation creates
  % false page breaks for questions that would otherwise fit.
  \Needspace{4\baselineskip}%
  \par\addvspace{0.45em}\noindent
  \gdef\qbank@currentquestion{#2}%
  \typeout{QBANKQUESTION phase=start id=#2 page=\thepage\space pagetotal=\the\pagetotal\space pagegoal=\the\pagegoal}%
  \textbf{\normalsize\color{brandink}#1.}\hspace{0.4em}\small\ignorespaces
}{\par\typeout{QBANKQUESTION phase=end id=\qbank@currentquestion\space page=\thepage\space pagetotal=\the\pagetotal\space pagegoal=\the\pagegoal}\vspace{0.2em}}

%% 标题与下一题开头联合分页，避免标题孤悬页尾。
\newcommand{\examsectionstart}[1]{%
  \par\addvspace{0.9em}\Needspace{11\baselineskip}%
  \noindent\qbanksquare{\sffamily\large\bfseries\color{brandink}#1}\par
  \vspace{0.1em}\noindent{\color{brandline}\rule{\linewidth}{0.3pt}}\par\addvspace{0.35em}}
\newcommand{\examsection}[1]{\examsectionstart{#1}}

%% ---- 讲义定理类盒子 ---------------------------------------------------
\newcounter{qbankbox}[section]
\renewcommand{\theqbankbox}{\thesection.\arabic{qbankbox}}
\tcbset{qbankthm/.style={%
  enhanced,breakable,colback=white,colframe=brandink,boxrule=0.5pt,arc=0.7mm,
  fonttitle=\bfseries\sffamily\color{white},colbacktitle=brandink,
  coltitle=white,attach boxed title to top left={xshift=2.4mm,yshift=-2.6mm},
  boxed title style={colback=brandink,colframe=brandink,arc=0.5mm,boxrule=0pt},
  left=2.8mm,right=2.6mm,top=2.4mm,bottom=2.2mm,
  before skip=0.75em,after skip=0.6em}}

\newtcolorbox[use counter=qbankbox]{definition}[1][]{qbankthm,title={定义~\theqbankbox\ #1}}
\newtcolorbox[use counter=qbankbox]{proposition}[1][]{qbankthm,title={性质~\theqbankbox\ #1}}
\newtcolorbox[use counter=qbankbox]{example}[1][]{qbankthm,title={例~\theqbankbox\ #1}}
\newtcolorbox[use counter=qbankbox]{exercise}[1][]{qbankthm,title={练习~\theqbankbox\ #1}}
% 方法/要点盒子（无标题条，浅底）
\newtcolorbox{keybox}{enhanced,breakable,colback=brandtint,colframe=brandink!55,
  boxrule=0.4pt,leftrule=2pt,arc=0.7mm,left=2.6mm,right=2.4mm,top=1.6mm,bottom=1.6mm,
  before skip=0.7em,after skip=0.6em}
% 小结盒子（暖色细边）
\newtcolorbox{summary}{enhanced,breakable,colback=white,colframe=brandwarm!70,
  boxrule=0.5pt,arc=0.7mm,left=2.6mm,right=2.4mm,top=1.8mm,bottom=1.8mm,
  before skip=0.7em,after skip=0.6em,
  overlay unbroken and first={\node[anchor=north west,font=\bfseries\sffamily\color{brandwarm},
    inner sep=0pt] at ([xshift=2.8mm,yshift=-1.6mm]frame.north west){本节小结};},
  top=5mm}

\endinput
